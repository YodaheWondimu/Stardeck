        </mxCell>
        <mxCell id="8XnBreUCT-JYY0ZVotU6-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Power Budget (Typical Use):&lt;br&gt;&lt;br&gt;&lt;div&gt;Pi:&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;~4 W&lt;/div&gt;&lt;div&gt;Display:&amp;nbsp; &amp;nbsp; &amp;nbsp; ~3 W&lt;/div&gt;&lt;div&gt;Keyboard:&amp;nbsp; &amp;nbsp; &amp;nbsp;~0.5 W&lt;/div&gt;&lt;div&gt;microSD:&amp;nbsp; &amp;nbsp; &amp;nbsp; ~0.2 W&lt;/div&gt;&lt;div&gt;Flash drive:&amp;nbsp; ~0.5 W&lt;/div&gt;&lt;div&gt;--------------------&lt;/div&gt;&lt;div&gt;Total:&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; ~8.2 W&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="240" x="80" y="360" as="geometry" />
        </mxCell>
        <mxCell id="WtJCig7mFAlkZNmW-nJa-2" edge="1" parent="1" source="y-PHCpSBWDV0tC5of_yL-1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" value="">
