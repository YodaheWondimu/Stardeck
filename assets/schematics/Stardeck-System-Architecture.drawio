          </mxGeometry>
        </mxCell>
        <mxCell id="y-PHCpSBWDV0tC5of_yL-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Power Budget (Upper Load):&lt;br&gt;&lt;br&gt;&lt;div&gt;&lt;div&gt;Pi:&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;~7 W&lt;/div&gt;&lt;div&gt;Display:&amp;nbsp; &amp;nbsp; &amp;nbsp; ~4 W&lt;/div&gt;&lt;div&gt;Keyboard:&amp;nbsp; &amp;nbsp; &amp;nbsp;~1 W&lt;/div&gt;&lt;div&gt;microSD:&amp;nbsp; &amp;nbsp; &amp;nbsp; ~0.5 W&lt;/div&gt;&lt;div&gt;Flash drive:&amp;nbsp; ~1 W&lt;/div&gt;&lt;div&gt;--------------------&lt;/div&gt;&lt;div&gt;Total:&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; ~13.5 W&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="240" x="400" y="360" as="geometry" />
        </mxCell>
        <mxCell id="e4Bpk4awr4HywQyZ-Fhi-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Port Map for Raspberry Pi 4B:&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;USB 3.0 &lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(51, 51, 255));&quot;&gt;(Blue)&lt;/font&gt; Port 1 → Flash Drive&lt;/div&gt;&lt;div&gt;USB 2.0 &lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(77, 77, 77));&quot;&gt;(Black)&lt;/font&gt; Port 1 → Keyboard&lt;/div&gt;&lt;div&gt;Micro-HDMI Port 0 → Display&lt;/div&gt;&lt;div&gt;USB-C → Power Bank&lt;/div&gt;" vertex="1">
          <mxGeometry height="150" width="250" x="640" y="80" as="geometry" />
        </mxCell>
