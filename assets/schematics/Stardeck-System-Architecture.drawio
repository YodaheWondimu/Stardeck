        <mxCell id="6xCh8BP1kyzRnyO1lW7G-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;div&gt;Software Stack&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;OS:&lt;/div&gt;&lt;div&gt;• Raspberry Pi OS Lite&lt;br&gt;- - Lower memory usage&lt;/div&gt;&lt;div&gt;- - Faster boot times&lt;/div&gt;&lt;div&gt;- - Optimized for terminal workflows&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Primary Interface:&lt;/div&gt;&lt;div&gt;• Terminal&lt;/div&gt;&lt;div&gt;• File management scripts&lt;/div&gt;&lt;div&gt;• Local utilities&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Storage:&lt;/div&gt;&lt;div&gt;• microSD → operating system&lt;/div&gt;&lt;div&gt;• USB drive → user files&lt;/div&gt;" vertex="1">
          <mxGeometry height="260" width="250" x="360" y="80" as="geometry" />
        </mxCell>
        <mxCell id="y-PHCpSBWDV0tC5of_yL-2" edge="1" parent="1" source="8XnBreUCT-JYY0ZVotU6-1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="y-PHCpSBWDV0tC5of_yL-1" value="">
